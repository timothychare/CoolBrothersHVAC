# Cool Brothers HVAC - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit the .env file to version control

# API Keys
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
EMAILJS_USER_ID=your_emailjs_user_id_here

# Business Configuration
BUSINESS_NAME=Cool Brothers HVAC
BUSINESS_EMAIL=info@coolbrothershvac.com
BUSINESS_PHONE=+15551234567
EMERGENCY_PHONE=+15551234567
BUSINESS_ADDRESS=123 Main St, Springfield, USA

# Social Media
FACEBOOK_URL=https://facebook.com/coolbrothershvac
TWITTER_URL=https://twitter.com/coolbrothershvac
LINKEDIN_URL=https://linkedin.com/company/coolbrothershvac
GOOGLE_BUSINESS_URL=https://g.page/coolbrothershvac

# Development/Production Settings
ENVIRONMENT=development
DEBUG_MODE=true
API_BASE_URL=https://api.coolbrothershvac.com

# Feature Flags
ENABLE_CHAT_WIDGET=false
ENABLE_BOOKING_SYSTEM=false
ENABLE_PAYMENT_PROCESSING=false